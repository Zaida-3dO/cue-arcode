{
  "name": "cue-arcode",
  "version": "0.1.0",
  "description": "QR code generator + dynamic-redirect management console (Cloudflare Bulk Redirects + styled QR codes)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c blue,green \"npm:watch:frontend\" \"npm:dev:backend\"",
    "dev:backend": "tsx watch src/server.ts",
    "watch:frontend": "node esbuild.config.mjs --watch",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "node esbuild.config.mjs",
    "build:backend": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p frontend/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "jsqr": "^1.4.0",
    "qr-code-styling": "^1.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
